{
  "name": "google-recorder-cli",
  "version": "1.0.0",
  "description": "CLI tool for downloading transcripts and audio from Google Recorder",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "google-recorder": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "auth": "tsx src/cli.ts auth",
    "list": "tsx src/cli.ts list",
    "download": "tsx src/cli.ts download"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "commander": "^12.1.0",
    "playwright-core": "^1.58.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
